{
  "name": "pdf-to-text",
  "version": "1.3.1",
  "description": "PDF to Text Translation Tool with Electron UI",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "electron:dev": "concurrently \"webpack serve --mode development\" \"sleep 8 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "jspdf": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "html-webpack-plugin": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2"
  },
  "build": {
    "appId": "com.pdftotext.app",
    "productName": "PDF to Text",
    "publish": null,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "scripts/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage",
        "snap"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
